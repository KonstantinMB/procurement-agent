# Copy to server/.env and fill in. Everything is optional — Procura runs a fully
# scripted demo with NO keys. Configure only the side-effects you want LIVE.

# The search bar always drives the live Claude Agent SDK.
# Auth comes from your logged-in `claude` CLI — no ANTHROPIC_API_KEY needed.

# ── Live phone call (Vapi: Claude brain + ElevenLabs voice) ────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=
FALLBACK_PHONE_NUMBER=     # E.164 (e.g. +359...) — dialed when a supplier has no number
DEMO_DIAL_FALLBACK=        # set to "true" for demo: route ALL calls to FALLBACK_PHONE_NUMBER
                           # (your phone), regardless of discovered supplier numbers.
ELEVENLABS_API_KEY=        # add this in the Vapi dashboard (Integrations) too

# ── Real RFQ emails (Nodemailer / Gmail app password) ──────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Real Purchase Order email (Resend) ─────────────────────────────────────
RESEND_API_KEY=               # https://resend.com/api-keys
RESEND_FROM_EMAIL=            # e.g. "Procura <orders@yourdomain.com>" (must be verified in Resend).
                              # If unset, defaults to "Procura <onboarding@resend.dev>" — works for demo,
                              # but Resend will only deliver to YOUR verified address until you add a domain.
BUYER_EMAIL=                  # YOUR inbox. In DEMO_DIAL_FALLBACK mode the PO is sent here instead
                              # of the real supplier; in normal mode it is CC'd.

# ── Optional ───────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=      # only if bringing your own number into Vapi
# TWILIO_AUTH_TOKEN=
# TWILIO_NUMBER=
# OPENAI_API_KEY=          # Vapi's default transcriber is fine without this
# PORT=8787
